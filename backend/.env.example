PORT=5000
NODE_ENV=development
SKIP_AUTH=true

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=rybella_iraq

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# API URL (for image URLs in responses)
API_URL=http://localhost:5000

# External inventory sync (Alhayaa / POS — same as bashir app)
# Base URL including /api/v1 if your server uses that prefix
EXTERNAL_INVENTORY_API_URL=
EXTERNAL_INVENTORY_API_TOKEN=
# Auto-refresh all catalog barcodes every N minutes (default 5)
INVENTORY_SYNC_INTERVAL_MIN=5
