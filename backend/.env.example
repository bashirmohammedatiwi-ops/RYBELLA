PORT=5000
NODE_ENV=development
SKIP_AUTH=true

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=rybella_iraq

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# API URL (for image URLs in responses)
API_URL=http://localhost:5000

# Web Push (إشعارات الهاتف للمتجر — اختياري، يُولَّد تلقائياً محلياً)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rybella.iq

# External inventory sync (Alhayaa / POS — same as bashir app)
EXTERNAL_INVENTORY_API_URL=http://187.127.88.146/api/v1
EXTERNAL_INVENTORY_API_EMAIL=
EXTERNAL_INVENTORY_API_PASSWORD=
EXTERNAL_INVENTORY_API_TOKEN=
INVENTORY_SYNC_INTERVAL_MIN=5
