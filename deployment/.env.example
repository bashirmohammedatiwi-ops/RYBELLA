# Rybella Iraq - Production Environment Variables
# Copy this file to .env and update the values

# HTTP port for public access (default: 4000)
HTTP_PORT=4000

# Web store port (default: 4003)
WEBSTORE_PORT=4003

# JWT Authentication
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRES_IN=7d

# API URL (used for image URLs in API responses)
# محلي: http://localhost:4000  |  إنتاج Rybella: https://rybellairaq.com
API_URL=https://rybellairaq.com

# Upload settings (bytes, 5242880 = 5MB)
MAX_FILE_SIZE=5242880

# External inventory sync (Alhayaa / POS — same as bashir app)
# Base URL including /api/v1 if your server uses that prefix
# Example: https://your-alhayaa-server.com/api/v1
EXTERNAL_INVENTORY_API_URL=
EXTERNAL_INVENTORY_API_TOKEN=
# Auto-refresh all catalog barcodes every N minutes (default 5)
INVENTORY_SYNC_INTERVAL_MIN=5
