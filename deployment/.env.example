# Rybella Iraq - Production Environment Variables
# Copy this file to .env and update the values

# HTTP port for public access (default: 80)
HTTP_PORT=80

# JWT Authentication
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRES_IN=7d

# API URL (used for image URLs in API responses - use your domain)
API_URL=http://localhost

# Upload settings (bytes, 5242880 = 5MB)
MAX_FILE_SIZE=5242880
