# عنوان API للاتصال بـ Backend
# قم بنسخ هذا الملف إلى .env وتعديل القيمة حسب الحاجة
#
# السيرفر البعيد (الإنتاج):
# EXPO_PUBLIC_API_URL=http://187.124.23.65:4000
#
# التطوير المحلي - التطبيق يختار تلقائياً إذا لم تحدد:
#   - ويب / آيفون محاكي: http://localhost:5000
#   - أندرويد محاكي: http://10.0.2.2:5000
#
# جهاز أندرويد حقيقي (Backend محلي):
# EXPO_PUBLIC_API_URL=http://192.168.1.5:5000
